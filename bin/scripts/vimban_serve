# ============================================================================
# TOKEN AUTH
# ============================================================================
def _load_tokens(token_path: _Path = TOKEN_FILE) -> dict[str, str]:
    """
    Load valid API tokens from the token file.

    Token file format supports two styles:
      - username:token  -> maps token to username
      - bare_token      -> maps token to 'unknown' (backward compat)

    Lines starting with '#' are comments. Blank lines are ignored.

    Args:
        token_path: Path to the token file

    Returns:
        Dict mapping token -> username
    """
    tokens: dict[str, str] = {}
    if not token_path.exists():
        return tokens
    try:
        with open(token_path, "r") as f:
            for line in f:
                stripped: str = line.strip()
                if not stripped or stripped.startswith("#"):
                    continue
                if ":" in stripped:
                    username, token = stripped.split(":", 1)
                    tokens[token.strip()] = username.strip()
                else:
                    tokens[stripped] = "unknown"
    except OSError:
        pass
    return tokens


def _resolve_remote(remote_str: str) -> tuple[str, str | None]:
    """
    Resolve a --remote value to (url, token).

    Supports:
        - Direct URL: "http://host:5005" or "https://host:5005"
        - Config lookup: "config:<name>" reads ~/.config/vimban/remote.yaml

    Args:
        remote_str: The --remote argument value

    Returns:
        Tuple of (base_url, api_token_or_None)
    """
    if remote_str.startswith("config:"):
        name: str = remote_str[7:]
        if not REMOTE_CONFIG_FILE.exists():
            print(f"Error: remote config file not found: {REMOTE_CONFIG_FILE}", file=sys.stderr)
            sys.exit(1)
        if yaml is None:
            print("Error: PyYAML required for config: remote resolution", file=sys.stderr)
            sys.exit(1)
        with open(REMOTE_CONFIG_FILE, "r") as f:
            data: dict = yaml.safe_load(f) or {}
        if name not in data:
            print(f"Error: remote '{name}' not found in {REMOTE_CONFIG_FILE}", file=sys.stderr)
            print(f"Available remotes: {', '.join(data.keys())}", file=sys.stderr)
            sys.exit(1)
        entry: dict = data[name]
        url: str = entry.get("url", "")
        token: str | None = entry.get("api_token", None)
        if not url:
            print(f"Error: remote '{name}' has no url defined", file=sys.stderr)
            sys.exit(1)
        return (url.rstrip("/"), token)
    else:
        return (remote_str.rstrip("/"), None)


def _remote_request(
    base_url: str,
    method: str,
    path: str,
    token: str | None = None,
    data: dict | None = None,
    params: dict | None = None,
) -> dict:
    """
    Make an HTTP request to a remote vimban_serve instance.

    Uses urllib.request (stdlib only) to avoid extra dependencies
    on the client side.

    Args:
        base_url: Base URL of the remote server (e.g. http://host:5005)
        method: HTTP method (GET, POST)
        path: API path (e.g. /api/tickets)
        token: Bearer token for auth (None to skip)
        data: JSON body for POST requests
        params: Query parameters for GET requests

    Returns:
        Parsed JSON response dict

    Raises:
        SystemExit on connection errors or auth failures
    """
    url: str = f"{base_url}{path}"
    if params:
        query: str = urllib.parse.urlencode(
            {k: v for k, v in params.items() if v}
        )
        if query:
            url = f"{url}?{query}"

    body: bytes | None = None
    if data is not None:
        body = json.dumps(data).encode("utf-8")

    req: urllib.request.Request = urllib.request.Request(url, data=body, method=method)
    req.add_header("Content-Type", "application/json")
    req.add_header("Accept", "application/json")
    if token:
        req.add_header("Authorization", f"Bearer {token}")

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            resp_data: bytes = resp.read()
            return json.loads(resp_data)
    except urllib.error.HTTPError as e:
        if e.code == 401:
            print("Error: authentication failed (401 Unauthorized)", file=sys.stderr)
            print("Check your API token or use --no-token if auth is disabled", file=sys.stderr)
            sys.exit(1)
        elif e.code == 404:
            print(f"Error: not found (404): {path}", file=sys.stderr)
            sys.exit(1)
        else:
            body_text: str = ""
            try:
                body_text = e.read().decode("utf-8", errors="replace")
            except Exception:
                pass
            print(f"Error: HTTP {e.code}: {body_text}", file=sys.stderr)
            sys.exit(1)
    except urllib.error.URLError as e:
        print(f"Error: cannot connect to {base_url}: {e.reason}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: request failed: {e}", file=sys.stderr)
        sys.exit(1)


# ============================================================================
# VIMBAN CLI INTERFACE
# ============================================================================
def _vimban_cmd(args: list[str], timeout: int = 30) -> tuple[int, str, str]:
    """
    Run a vimban CLI command and capture output.

    Global flags (-f, --work, --personal, --archived) are extracted from
    args and placed before the subcommand so argparse parses them correctly.

    Args:
        args: Command arguments (without 'vimban' prefix)
        timeout: Command timeout in seconds

    Returns:
        Tuple of (return_code, stdout, stderr)
    """
    # extract global flags that must come before the subcommand
    global_flags: list[str] = []
    subcmd_args: list[str] = []
    i: int = 0
    while i < len(args):
        if args[i] in ("-f", "--format") and i + 1 < len(args):
            global_flags.extend([args[i], args[i + 1]])
            i += 2
        elif args[i] in ("--work", "--personal", "--archived"):
            global_flags.append(args[i])
            i += 1
        else:
            subcmd_args.append(args[i])
            i += 1

    cmd: list[str] = ["vimban", "--no-color", "-q"] + global_flags + subcmd_args
    env: dict[str, str] = os.environ.copy()
    env["NO_DBOX_CHECK"] = "1"
    try:
        result: subprocess.CompletedProcess = subprocess.run(
            cmd, capture_output=True, text=True, timeout=timeout, env=env
        )
        return (result.returncode, result.stdout, result.stderr)
    except subprocess.TimeoutExpired:
        return (1, "", "Command timed out")
    except FileNotFoundError:
        return (1, "", "vimban not found in PATH")


def _parse_yaml_output(stdout: str) -> list[dict[str, Any]]:
    """
    Parse YAML-format output from vimban list.

    Args:
        stdout: Raw stdout from vimban list -f yaml

    Returns:
        List of ticket dicts
    """
    try:
        import yaml
        data: Any = yaml.safe_load(stdout)
        if isinstance(data, list):
            return data
        return []
    except Exception:
        return []


def _parse_json_output(stdout: str) -> Any:
    """
    Parse JSON-format output from vimban commands.

    Args:
        stdout: Raw stdout from vimban -f json

    Returns:
        Parsed data structure
    """
    try:
        return json.loads(stdout)
    except (json.JSONDecodeError, ValueError):
        return None


def list_tickets(
    status: str = "",
    ticket_type: str = "",
    assignee: str = "",
    priority: str = "",
    project: str = "",
    search: str = "",
    work: bool = False,
    personal: bool = False,
    include_done: bool = False,
) -> list[dict[str, Any]]:
    """
    List tickets with optional filters.

    Returns:
        List of ticket dicts with frontmatter fields
    """
    args: list[str] = ["list", "-f", "json"]
    if status:
        args.extend(["-s", status])
    if ticket_type:
        args.extend(["-t", ticket_type])
    if assignee:
        args.extend(["--assignee", assignee])
    if priority:
        args.extend(["--priority", priority])
    if project:
        args.extend(["-P", project])
    if work:
        args.append("--work")
    if personal:
        args.append("--personal")
    if include_done:
        args.append("--archived")

    rc, stdout, stderr = _vimban_cmd(args)
    if rc != 0:
        return []

    data: Any = _parse_json_output(stdout)
    if isinstance(data, list):
        return data
    return []


def get_ticket(ticket_id: str) -> Optional[dict[str, Any]]:
    """
    Get a single ticket by ID.

    Args:
        ticket_id: The ticket ID (e.g., PROJ-00042)

    Returns:
        Ticket dict or None
    """
    rc, stdout, stderr = _vimban_cmd(["show", ticket_id, "-f", "json"])
    if rc != 0:
        return None
    return _parse_json_output(stdout)


def create_ticket(
    ticket_type: str,
    title: str,
    priority: str = "medium",
    assignee: str = "",
    reporter: str = "",
    project: str = "",
    tags: str = "",
    due: str = "",
    member_of: str = "",
    work: bool = False,
    personal: bool = False,
    prefix: Optional[str] = None,
) -> tuple[bool, str]:
    """
    Create a new ticket.

    Returns:
        Tuple of (success, message_or_id)
    """
    args: list[str] = ["create", ticket_type, title, "--no-edit", "-p", priority]
    if assignee:
        args.extend(["-a", assignee])
    if reporter:
        args.extend(["-r", reporter])
    if project:
        args.extend(["-P", project])
    if tags:
        args.extend(["-t", tags])
    if due:
        args.extend(["--due", due])
    if member_of:
        args.extend(["-m", member_of])
    if work:
        args.append("--work")
    if personal:
        args.append("--personal")
    if prefix:
        args.extend(["--prefix", prefix])

    rc, stdout, stderr = _vimban_cmd(args)
    if rc != 0:
        return (False, stderr.strip() or "Failed to create ticket")

    # extract ticket ID from output
    match: Optional[re.Match] = re.search(r'([A-Z]+-\d+)', stdout)
    if match:
        return (True, match.group(1))
    return (True, stdout.strip())


def move_ticket(ticket_id: str, new_status: str) -> tuple[bool, str]:
    """
    Move a ticket to a new status.

    Returns:
        Tuple of (success, message)
    """
    rc, stdout, stderr = _vimban_cmd(["move", ticket_id, new_status])
    if rc != 0:
        return (False, stderr.strip() or "Failed to move ticket")
    return (True, f"Moved {ticket_id} to {new_status}")


def add_comment(ticket_id: str, text: str) -> tuple[bool, str]:
    """
    Add a comment to a ticket.

    Returns:
        Tuple of (success, message)
    """
    rc, stdout, stderr = _vimban_cmd(["comment", ticket_id, text])
    if rc != 0:
        return (False, stderr.strip() or "Failed to add comment")
    return (True, "Comment added")


def edit_ticket(ticket_id: str, fields: dict[str, str]) -> tuple[bool, str]:
    """
    Edit ticket fields.

    Args:
        ticket_id: Ticket ID
        fields: Dict of field name to new value

    Returns:
        Tuple of (success, message)
    """
    args: list[str] = ["edit", ticket_id]
    for field, value in fields.items():
        if field == "priority":
            args.extend(["--priority", value])
        elif field == "assignee":
            args.extend(["--assignee", value])
        elif field == "progress":
            args.extend(["--progress", value])
        elif field == "tags":
            args.extend(["--tags", value])
        elif field == "due_date":
            args.extend(["--due", value])

    rc, stdout, stderr = _vimban_cmd(args)
    if rc != 0:
        return (False, stderr.strip() or "Failed to edit ticket")
    return (True, "Ticket updated")


def get_dashboard(dashboard_type: str = "daily") -> str:
    """
    Get dashboard output.

    Returns:
        Dashboard text content
    """
    rc, stdout, stderr = _vimban_cmd(["dashboard", dashboard_type])
    if rc != 0:
        return f"Error: {stderr}"
    return stdout


def get_kanban() -> str:
    """
    Get kanban board output.

    Returns:
        Kanban text content
    """
    rc, stdout, stderr = _vimban_cmd(["kanban"])
    if rc != 0:
        return f"Error: {stderr}"
    return stdout


def search_tickets(query: str) -> list[dict[str, Any]]:
    """
    Search tickets by keyword.

    Returns:
        List of matching ticket dicts
    """
    rc, stdout, stderr = _vimban_cmd(["search", query, "-f", "json"])
    if rc != 0:
        return []
    data: Any = _parse_json_output(stdout)
    if isinstance(data, list):
        return data
    return []


def list_people() -> list[dict[str, Any]]:
    """
    List people.

    Returns:
        List of people dicts
    """
    rc, stdout, stderr = _vimban_cmd(["people", "list", "-f", "json"])
    if rc != 0:
        return []
    data: Any = _parse_json_output(stdout)
    if isinstance(data, list):
        return data
    return []


def git_sync() -> tuple[bool, str]:
    """
    Run vimban commit (git sync).

    Returns:
        Tuple of (success, message)
    """
    rc, stdout, stderr = _vimban_cmd(["commit"], timeout=60)
    if rc != 0:
        return (False, stderr.strip() or "Sync failed")
    return (True, stdout.strip() or "Synced successfully")


# ============================================================================
# QUART APP
# ============================================================================
app: Quart = Quart(__name__)
app = cors(app, allow_origin="*")

# auth state — set at startup based on --no-token flag
_auth_enabled: bool = True
_valid_tokens: dict[str, str] = {}  # token -> username


# --- SSE Collaboration Broker ---
_sse_clients: dict[str, asyncio.Queue] = {}  # client_id -> Queue
_presence: dict[str, dict] = {}  # client_id -> {user, connected_at, viewing}


def _get_presence_list() -> list[dict]:
    """Return list of currently connected users."""
    seen_users = {}
    for cid, info in _presence.items():
        user = info['user']
        if user not in seen_users:
            seen_users[user] = {'user': user, 'connected_at': info['connected_at'], 'viewing': info.get('viewing')}
    return list(seen_users.values())


async def _broadcast_event(event_type: str, data: dict) -> None:
    """Broadcast an SSE event to all connected clients."""
    payload = json.dumps({'type': event_type, 'data': data, 'ts': time.time()})
    dead = []
    for cid, q in list(_sse_clients.items()):
        try:
            q.put_nowait(payload)
        except asyncio.QueueFull:
            dead.append(cid)
    for cid in dead:
        _sse_clients.pop(cid, None)
        _presence.pop(cid, None)


@app.before_request
async def _check_auth():
    """
    Token-based auth middleware.

    Validates Bearer token on all /api/* routes. Skips auth for:
    - GET / (HTML UI page)
    - GET /api/health (health check)
    - All routes when --no-token is active

    Sets g.vimban_user to the resolved username for authenticated requests,
    or None for unauthenticated bypass paths.
    """
    if not _auth_enabled:
        g.vimban_user = None
        return None

    path: str = request.path

    # skip auth for the HTML UI, health check, and presence list
    if path == "/" or path == "/api/health" or path == "/api/presence":
        g.vimban_user = None
        return None

    # only protect /api/* routes
    if not path.startswith("/api/"):
        g.vimban_user = None
        return None

    auth_header: str | None = request.headers.get("Authorization")
    if auth_header:
        if not auth_header.startswith("Bearer "):
            return jsonify({"error": "unauthorized", "message": "Bearer token required"}), 401
        token: str = auth_header[7:]
        if token in _valid_tokens:
            g.vimban_user = _valid_tokens[token]
            return None
        return jsonify({"error": "unauthorized", "message": "Invalid token"}), 401

    # fallback: check query-param token (for SSE EventSource clients that can't set headers)
    token = request.args.get('token', '')
    if token and token in _valid_tokens:
        g.vimban_user = _valid_tokens[token]
        return None

    return jsonify({"error": "unauthorized", "message": "Authorization header required"}), 401


