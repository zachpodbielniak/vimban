                           placeholder="Search tickets..." onkeyup="filterList()">
                </div>
                <div class="filters">
                    <select id="listStatus" onchange="loadList()">
                        <option value="">All statuses</option>
                        <option value="backlog">Backlog</option>
                        <option value="ready">Ready</option>
                        <option value="in_progress">In Progress</option>
                        <option value="blocked">Blocked</option>
                        <option value="review">Review</option>
                        <option value="delegated">Delegated</option>
                        <option value="done">Done</option>
                        <option value="cancelled">Cancelled</option>
                    </select>
                    <select id="listPriority" onchange="loadList()">
                        <option value="">All priorities</option>
                        <option value="critical">Critical</option>
                        <option value="high">High</option>
                        <option value="medium">Medium</option>
                        <option value="low">Low</option>
                    </select>
                    <select id="listType" onchange="loadList()">
                        <option value="">All types</option>
                        <option value="task">Task</option>
                        <option value="bug">Bug</option>
                        <option value="story">Story</option>
                        <option value="epic">Epic</option>
                        <option value="research">Research</option>
                        <option value="sub-task">Sub-task</option>
                    </select>
                    <select id="listScope" onchange="loadList()">
                        <option value="">All scopes</option>
                        <option value="work">Work</option>
                        <option value="personal">Personal</option>
                    </select>
                </div>
            </div>
            <div class="table-container">
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th onclick="sortList('id')">ID</th>
                                <th onclick="sortList('type')">Type</th>
                                <th onclick="sortList('status')">Status</th>
                                <th onclick="sortList('priority')">Priority</th>
                                <th onclick="sortList('assignee')">Assignee</th>
                                <th onclick="sortList('title')">Title</th>
                                <th onclick="sortList('progress')">Progress</th>
                                <th onclick="sortList('due_date')">Due</th>
                            </tr>
                        </thead>
                        <tbody id="listBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- DASHBOARD VIEW -->
        <div class="view-panel" id="view-dashboard">
            <div class="dashboard-tabs">
                <button class="btn btn-secondary btn-small active" onclick="loadDashboard('daily', this)">Daily</button>
                <button class="btn btn-secondary btn-small" onclick="loadDashboard('weekly', this)">Weekly</button>
                <button class="btn btn-secondary btn-small" onclick="loadDashboard('sprint', this)">Sprint</button>
                <button class="btn btn-secondary btn-small" onclick="loadDashboard('project', this)">Project</button>
                <button class="btn btn-secondary btn-small" onclick="loadDashboard('team', this)">Team</button>
            </div>
            <div class="dashboard-content" id="dashboardContent">Loading...</div>
        </div>

        <!-- PEOPLE VIEW -->
        <div class="view-panel" id="view-people">
            <div class="toolbar">
                <div class="search-box">
                    <input type="text" class="search-input" id="peopleSearch"
                           placeholder="Search people..." onkeyup="filterPeople()">
                </div>
            </div>
            <div class="people-grid" id="peopleGrid"></div>
        </div>
    </div>

    <!-- CREATE MODAL -->
    <div class="modal-overlay" id="createModal">
        <div class="modal">
            <div class="modal-header">
                <h2>Create Ticket</h2>
                <button class="modal-close" onclick="closeModal('createModal')">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Type</label>
                        <select id="createType">
                            <option value="task">Task</option>
                            <option value="bug">Bug</option>
                            <option value="story">Story</option>
                            <option value="epic">Epic</option>
                            <option value="sub-task">Sub-task</option>
                            <option value="research">Research</option>
                            <option value="meeting">Meeting</option>
                            <option value="journal">Journal</option>
                            <option value="recipe">Recipe</option>
                            <option value="mentorship">Mentorship</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Priority</label>
                        <select id="createPriority">
                            <option value="medium">Medium</option>
                            <option value="low">Low</option>
                            <option value="high">High</option>
                            <option value="critical">Critical</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Title</label>
                    <input type="text" id="createTitle" placeholder="Ticket title...">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Assignee</label>
                        <input type="text" id="createAssignee" placeholder="e.g. john_doe">
                    </div>
                    <div class="form-group">
                        <label>Reporter</label>
                        <input type="text" id="createReporter" placeholder="e.g. jane_doe">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Project</label>
                        <input type="text" id="createProject" placeholder="e.g. myapp">
                    </div>
                    <div class="form-group">
                        <label>Due Date</label>
                        <input type="text" id="createDue" placeholder="e.g. +7d, 2026-03-01">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Tags</label>
                        <input type="text" id="createTags" placeholder="comma-separated">
                    </div>
                    <div class="form-group">
                        <label>Member Of</label>
                        <input type="text" id="createMemberOf" placeholder="e.g. PROJ-00001">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Scope</label>
                        <select id="createScope">
                            <option value="">Default</option>
