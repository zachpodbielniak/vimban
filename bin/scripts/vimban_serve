        await _broadcast_event('TICKET_COMMENT', {'ticket_id': ticket_id, 'user': getattr(g, 'vimban_user', None) or request.headers.get('X-Vimban-User', 'unknown')})
    return jsonify({'success': success, 'message': msg})


