"""
vimban_serve - Web UI for vimban ticket management

A single-file async web server providing a full-featured web interface
for vimban. Equivalent to the TUI but in the browser, with kanban board,
list view, dashboards, search, and full CRUD operations.

Usage:
    vimban_serve [options]
    vimban --server [options]

Examples:
    vimban_serve
    vimban_serve --port 5005
    vimban_serve --bind 0.0.0.0 --port 8080
"""

# ============================================================================
# DISTROBOX CHECK (Before any other imports)
# ============================================================================
import os
import subprocess
import sys
from pathlib import Path as _Path


def _read_config_value(key: str, default: str = "") -> str:
    """
    Read a single top-level key from config.yaml using stdlib only.

    Args:
        key: The YAML key to look up
        default: Fallback if key is not found

    Returns:
        The value as a string, or default
    """
    config_path: _Path = _Path.home() / ".config" / "vimban" / "config.yaml"
    if not config_path.exists():
        return default
    try:
        with open(config_path, "r") as f:
            for line in f:
                stripped: str = line.strip()
                if stripped.startswith("#") or ":" not in stripped:
                    continue
                k, _, v = stripped.partition(":")
                if k.strip() == key:
                    val: str = v.strip().strip('"').strip("'")
                    return val if val else default
    except (OSError, ValueError):
        pass
    return default


ctr_id: str = os.environ.get("CONTAINER_ID", "")
no_dbox_check: bool = os.environ.get("NO_DBOX_CHECK", "").lower() in ("1", "true")
if not no_dbox_check:
    _cfg_dbox: str = _read_config_value("distrobox", "")
    if _cfg_dbox.lower() in ("", "false", "none", "disabled", "off"):
        no_dbox_check = True

_dbox_target: str = os.environ.get("VIMBAN_DISTROBOX", "") or _read_config_value("distrobox", "dev")

if not no_dbox_check and (_dbox_target != ctr_id):
    cmd: list[str] = ["distrobox", "enter", _dbox_target, "--", *sys.argv]
    subprocess.run(cmd)
    sys.exit(0)


