@app.route('/api/snapshot')
async def api_snapshot():
    """Return full current state snapshot for SSE client initialization.

    Called immediately after SSE connect so clients can reconcile any
    events missed before the stream was established.

    Returns:
        JSON with tickets list, presence list, and server timestamp.
    """
    tickets: list[dict[str, Any]] = list_tickets()
    presence: list[dict] = _get_presence_list()
    return jsonify({
        'tickets': tickets,
        'presence': presence,
        'ts': time.time(),
    })


@app.route('/api/events')
async def api_events():
    """SSE endpoint for real-time collaboration events."""
    _load_tokens()

    # Auth: check header OR query param (EventSource can't set headers)
    authed = not _auth_enabled
    if not authed:
        auth_header = request.headers.get('Authorization', '')
        if auth_header.startswith('Bearer '):
            token = auth_header[7:]
            authed = token in _valid_tokens
        if not authed:
            token = request.args.get('token', '')
            authed = token in _valid_tokens

    if not authed:
        return jsonify({'error': 'unauthorized', 'message': 'Valid token required'}), 401

    # Resolve user from token (authoritative identity — not spoofable via ?user=)
    token = request.headers.get('Authorization', '').removeprefix('Bearer ').strip() or request.args.get('token', '')
    user = _valid_tokens.get(token, 'unknown')
    client_id = str(uuid.uuid4())
    q: asyncio.Queue = asyncio.Queue(maxsize=100)
    _sse_clients[client_id] = q
    _presence[client_id] = {'user': user, 'connected_at': time.time(), 'viewing': None}

    # Notify others of new presence
    await _broadcast_event('PRESENCE_JOIN', {'user': user, 'presence': _get_presence_list()})

    async def event_stream():
        try:
            # Send initial connection confirmation with current presence
            connected_msg = json.dumps({
                'type': 'CONNECTED',
                'data': {'client_id': client_id, 'user': user, 'presence': _get_presence_list()},
                'ts': time.time()
            })
            yield f'data: {connected_msg}\n\n'

            while True:
                try:
                    msg = await asyncio.wait_for(q.get(), timeout=30.0)
                    yield f'data: {msg}\n\n'
                except asyncio.TimeoutError:
                    # Keepalive comment to prevent connection timeout
                    yield f': ping {int(time.time())}\n\n'
        finally:
            _sse_clients.pop(client_id, None)
            _presence.pop(client_id, None)
            # Fire and forget presence leave (we're in a generator finally block)
            asyncio.ensure_future(
                _broadcast_event('PRESENCE_LEAVE', {'user': user, 'presence': _get_presence_list()})
            )

    response = await make_response(
        event_stream(),
        200,
        {
            'Content-Type': 'text/event-stream',
            'Cache-Control': 'no-cache',
            'X-Accel-Buffering': 'no',
            'Connection': 'keep-alive',
        }
    )
    return response


@app.route('/api/ticket/<ticket_id>/archive', methods=['POST'])
async def api_archive_ticket(ticket_id: str):
    """Archive a ticket (move to archived status)."""
    rc, stdout, stderr = _vimban_cmd(["archive", ticket_id])
    if rc != 0:
        return jsonify({'success': False, 'message': stderr.strip() or 'Failed to archive'}), 400
    await _broadcast_event('TICKET_ARCHIVED', {'ticket_id': ticket_id, 'user': getattr(g, 'vimban_user', None) or request.headers.get('X-Vimban-User', 'unknown')})
    return jsonify({'success': True, 'message': f'Archived {ticket_id}'})


@app.route('/api/ticket/<ticket_id>/comments')
async def api_get_comments(ticket_id: str):
    """Get comments for a ticket."""
    rc, stdout, stderr = _vimban_cmd(["comments", ticket_id, "-f", "json"])
    if rc != 0:
        return jsonify({'comments': [], 'error': stderr.strip()}), 400
    data: Any = _parse_json_output(stdout)
    if isinstance(data, list):
        return jsonify({'comments': data})
    return jsonify({'comments': data.get('comments', []) if isinstance(data, dict) else []})


@app.route('/api/ticket/<ticket_id>/link', methods=['POST'])
async def api_link_tickets(ticket_id: str):
    """Link a ticket to another ticket."""
    data: dict = await request.get_json()
    target: str = data.get('target', '')
    link_type: str = data.get('type', 'related')
    if not target:
        return jsonify({'success': False, 'message': 'Target ticket ID required'}), 400

    rc, stdout, stderr = _vimban_cmd(["link", ticket_id, target, "--type", link_type])
    if rc != 0:
        return jsonify({'success': False, 'message': stderr.strip() or 'Failed to link'}), 400
    return jsonify({'success': True, 'message': f'Linked {ticket_id} to {target}'})


@app.route('/api/report')
async def api_report():
    """Get report data."""
    report_type: str = request.args.get('type', 'summary')
    rc, stdout, stderr = _vimban_cmd(["report", report_type, "-f", "json"])
    if rc != 0:
        # fallback to plain text if json not supported for this report
        rc, stdout, stderr = _vimban_cmd(["report", report_type])
        return jsonify({'content': stdout, 'format': 'text'})
    data: Any = _parse_json_output(stdout)
    if data is not None:
        return jsonify({'report': data, 'format': 'json'})
    return jsonify({'content': stdout, 'format': 'text'})


@app.route('/api/kanban')
async def api_kanban():
    """Get kanban board data as structured JSON."""
    # get tickets grouped by status for kanban rendering
    tickets: list[dict[str, Any]] = list_tickets(
        work=(request.args.get('scope') == 'work'),
        personal=(request.args.get('scope') == 'personal'),
    )
    # group by status
    board: dict[str, list[dict]] = {s: [] for s in STATUSES}
    for t in tickets:
        status: str = t.get('status', 'backlog')
        if status in board:
            board[status].append(t)
        else:
            board.setdefault(status, []).append(t)
    return jsonify({'board': board})


@app.route('/api/commit', methods=['POST'])
async def api_commit():
    """Run vimban commit (with optional --pull)."""
    data: dict = await request.get_json() or {}
    cmd_args: list[str] = ["commit"]
    if data.get('pull', False):
        cmd_args.append("--pull")
    rc, stdout, stderr = _vimban_cmd(cmd_args, timeout=60)
    if rc != 0:
        return jsonify({'success': False, 'message': stderr.strip() or 'Commit failed'}), 400
    return jsonify({'success': True, 'message': stdout.strip() or 'Committed'})


# ============================================================================
# PROXY MODE (--remote for chaining vimban_serve instances)
# ============================================================================
_proxy_url: str = ""
_proxy_token: str | None = None
_proxy_enabled: bool = False


def _setup_proxy_mode(remote_url: str, token: str | None) -> None:
    """
    Enable proxy mode: forward vimban CLI calls through a remote API.

    When proxy mode is active, all helper functions that call _vimban_cmd()
    will be transparently routed through the remote vimban_serve instead
    of invoking the local vimban binary. The list_tickets, get_ticket, etc.
    functions still work — they just go over HTTP now.

    Args:
        remote_url: Base URL of the remote server
        token: Bearer token for auth (or None)
    """
    global _proxy_url, _proxy_token, _proxy_enabled, _vimban_cmd
    _proxy_url = remote_url
    _proxy_token = token
    _proxy_enabled = True
    _vimban_cmd = _proxy_vimban_cmd


def _proxy_vimban_cmd(args: list[str], timeout: int = 30) -> tuple[int, str, str]:
    """
    Proxy a vimban command through a remote vimban_serve API.

    Maps CLI-style command args to the corresponding API endpoint
    and returns the response as if it came from a local vimban call.

    Args:
        args: Command arguments (same as _vimban_cmd)
        timeout: Request timeout

    Returns:
        Tuple of (return_code, stdout_json, stderr)
    """
    if not args:
        return (1, "", "No command provided")

    cmd: str = args[0]
    rest: list[str] = args[1:]

    try:
        if cmd == "list":
            params: dict[str, str] = {}
            i: int = 0
            while i < len(rest):
                if rest[i] in ("-s", "--status") and i + 1 < len(rest):
                    params["status"] = rest[i + 1]
                    i += 2
                elif rest[i] in ("-t", "--type") and i + 1 < len(rest):
                    params["type"] = rest[i + 1]
                    i += 2
                elif rest[i] == "--assignee" and i + 1 < len(rest):
                    params["assignee"] = rest[i + 1]
                    i += 2
                elif rest[i] == "--priority" and i + 1 < len(rest):
                    params["priority"] = rest[i + 1]
                    i += 2
                elif rest[i] in ("-P", "--project") and i + 1 < len(rest):
                    params["project"] = rest[i + 1]
                    i += 2
                elif rest[i] == "--work":
                    params["scope"] = "work"
                    i += 1
                elif rest[i] == "--personal":
                    params["scope"] = "personal"
                    i += 1
                elif rest[i] == "--archived":
                    params["include_done"] = "true"
                    i += 1
                else:
                    i += 1
            resp = _remote_request(_proxy_url, "GET", "/api/tickets", _proxy_token, params=params)
            return (0, json.dumps(resp.get("tickets", [])), "")

        elif cmd == "show" and rest:
            resp = _remote_request(_proxy_url, "GET", f"/api/ticket/{rest[0]}", _proxy_token)
            return (0, json.dumps(resp.get("ticket", {})), "")

        elif cmd == "search" and rest:
            resp = _remote_request(_proxy_url, "GET", "/api/search", _proxy_token, params={"q": rest[0]})
            return (0, json.dumps(resp.get("tickets", [])), "")

        elif cmd == "dashboard":
            dtype: str = rest[0] if rest else "daily"
            resp = _remote_request(_proxy_url, "GET", f"/api/dashboard/{dtype}", _proxy_token)
            return (0, resp.get("content", ""), "")

        elif cmd == "people":
            resp = _remote_request(_proxy_url, "GET", "/api/people", _proxy_token)
            return (0, json.dumps(resp.get("people", [])), "")

        elif cmd == "kanban":
            resp = _remote_request(_proxy_url, "GET", "/api/kanban", _proxy_token)
            return (0, json.dumps(resp.get("board", {})), "")

        elif cmd == "commit":
            pull: bool = "--pull" in rest
            resp = _remote_request(_proxy_url, "POST", "/api/commit", _proxy_token, data={"pull": pull})
            msg: str = resp.get("message", "")
            if resp.get("success"):
                return (0, msg, "")
            return (1, "", msg)

        elif cmd in ("move", "archive", "comment", "edit", "link"):
            # these are handled via the existing API in the route handlers
            # but the proxy just passes through the original _vimban_cmd
            return _original_vimban_cmd(args, timeout)

        else:
            # fallback: run locally
            return _original_vimban_cmd(args, timeout)

    except SystemExit:
        return (1, "", "Remote request failed")
    except Exception as e:
        return (1, "", str(e))


# store original _vimban_cmd before potential override
_original_vimban_cmd = _vimban_cmd


# ============================================================================
# MAIN
# ============================================================================
async def main() -> None:
    """Main entry point."""
    parser: argparse.ArgumentParser = argparse.ArgumentParser(
        description='vimban web server',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""Examples:
  vimban_serve                  Start on default port (5005)
  vimban_serve --port 8080      Start on port 8080
  vimban_serve --bind 0.0.0.0   Listen on all interfaces"""
    )
    parser.add_argument(
        '--bind', default=DEFAULT_BIND,
        help=f'Address to bind to (default: {DEFAULT_BIND})'
    )

    # port from config, then default
    config_port: str = _read_config_value("server_port", str(DEFAULT_PORT))
    default_port: int = int(config_port) if config_port.isdigit() else DEFAULT_PORT

    parser.add_argument(
        '--port', type=int, default=default_port,
        help=f'Port to bind to (default: {default_port})'
    )
    parser.add_argument('--debug', action='store_true', help='Enable debug mode')
    parser.add_argument('--license', action='store_true', help='Show license')
    parser.add_argument('-h2', '--help-keys', action='store_true', help='Show keyboard shortcuts')

    # auth options
    parser.add_argument(
        '--no-token', action='store_true',
        help='Disable token authentication (for testing or local-only setups)'
    )
    parser.add_argument(
        '--token-file', default=str(TOKEN_FILE),
        help=f'Path to token file (default: {TOKEN_FILE})'
    )

    # remote proxy options (for chaining to another vimban_serve)
    parser.add_argument(
        '--remote',
        help='Proxy to a remote vimban_serve (URL or config:<name>)'
    )
    parser.add_argument(
        '--api-token',
        help='API token for remote server authentication'
    )

    args: argparse.Namespace = parser.parse_args()

    if args.license:
        print(LICENSE_TEXT)
        return

    if args.help_keys:
        print("Keyboard shortcuts (when not focused on input):")
        print("  c       Create new ticket")
        print("  r       Refresh current view")
        print("  s       Git sync")
        print("  1-4     Switch views (Kanban, List, Dashboard, People)")
        print("  /       Focus search")
        print("  Esc     Close modals")
        return

    # configure auth
    global _auth_enabled, _valid_tokens
    if args.no_token:
        _auth_enabled = False
        print("  Auth    : DISABLED (--no-token)")
    else:
        token_path: _Path = _Path(args.token_file)
        _valid_tokens = _load_tokens(token_path)
        if _valid_tokens:
            _auth_enabled = True
            print(f"  Auth    : enabled ({len(_valid_tokens)} token(s) loaded from {token_path})")
        else:
            _auth_enabled = False
            print(f"  Auth    : DISABLED (no tokens found in {token_path})")

    # if --remote, set up proxy mode
    if args.remote:
        remote_url, remote_token = _resolve_remote(args.remote)
        if args.api_token:
            remote_token = args.api_token
        _setup_proxy_mode(remote_url, remote_token)
        print(f"  Proxy   : forwarding API calls to {remote_url}")

    print(f"Starting vimban web server on http://{args.bind}:{args.port}")
    print(f"  Kanban  : http://{args.bind}:{args.port}")
    print(f"  API     : http://{args.bind}:{args.port}/api/tickets")
    print()
    await app.run_task(host=args.bind, port=args.port, debug=args.debug)


if __name__ == '__main__':
    asyncio.run(main())
