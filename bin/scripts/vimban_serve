    </div>

    <!-- DETAIL MODAL -->
    <div class="modal-overlay" id="detailModal">
        <div class="modal" style="max-width:800px;">
            <div class="modal-header">
                <h2 id="detailTitle">Ticket Detail</h2>
                <button class="modal-close" onclick="closeModal('detailModal')">&times;</button>
            </div>
            <div class="modal-body" id="detailBody">Loading...</div>
        </div>
    </div>

    <!-- TOAST CONTAINER -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        /* ============================================================ */
        /* STATE                                                        */
        /* ============================================================ */
        let currentView = 'kanban';
        let allTickets = [];
        let listSortField = 'id';
        let listSortAsc = true;

        /* ============================================================ */
        /* UTILITIES                                                    */
        /* ============================================================ */
        function toast(msg, type = 'success') {
            const container = document.getElementById('toastContainer');
            const el = document.createElement('div');
            el.className = `toast toast-${type}`;
            el.textContent = msg;
            container.appendChild(el);
            setTimeout(() => el.remove(), 4000);
        }

        async function api(url, opts = {}) {
            try {
                const authHeader = collab.token
                    ? { 'Authorization': 'Bearer ' + collab.token }
                    : {};
                const resp = await fetch(url, {
                    headers: { 'Content-Type': 'application/json', ...authHeader },
                    ...opts
                });
                return await resp.json();
            } catch (e) {
                toast('Network error: ' + e.message, 'error');
                return null;
            }
        }

        function badgeHtml(value, prefix) {
            if (!value) return '';
            const cls = prefix + '-' + value.replace(/ /g, '_');
            return `<span class="badge ${cls}">${value.replace(/_/g, ' ')}</span>`;
        }

        function tagsHtml(tags) {
            if (!tags || !tags.length) return '';
            const arr = Array.isArray(tags) ? tags : String(tags).split(',');
            return '<div class="tags">' +
                arr.map(t => `<span class="tag">${t.trim()}</span>`).join('') +
                '</div>';
        }

        function progressHtml(val) {
            const v = parseInt(val) || 0;
            return `<div class="progress-bar-bg"><div class="progress-bar-fill" style="width:${v}%"></div></div>`;
        }

        function truncate(s, n) {
            if (!s) return '';
            return s.length > n ? s.substring(0, n) + '...' : s;
        }

        /* ============================================================ */
        /* VIEW SWITCHING                                               */
        /* ============================================================ */
        function switchView(view) {
            currentView = view;
            document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.view-panel').forEach(p => p.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('view-' + view).classList.add('active');

            if (view === 'kanban') loadKanban();
            else if (view === 'list') loadList();
            else if (view === 'dashboard') loadDashboard('daily');
            else if (view === 'people') loadPeople();
        }

        /* ============================================================ */
        /* STATS                                                        */
        /* ============================================================ */
        async function loadStats() {
            const data = await api('/api/tickets?include_done=false');
            if (!data) return;
            const tickets = data.tickets || [];
            allTickets = tickets;

            const counts = {};
            tickets.forEach(t => {
                const s = t.status || 'unknown';
                counts[s] = (counts[s] || 0) + 1;
            });

            const bar = document.getElementById('statsBar');
            bar.innerHTML = `
                <div class="stat-item"><span class="stat-value">${tickets.length}</span><span class="stat-label">Total</span></div>
                <div class="stat-item"><span class="stat-value">${counts.in_progress || 0}</span><span class="stat-label">In Progress</span></div>
                <div class="stat-item"><span class="stat-value">${counts.ready || 0}</span><span class="stat-label">Ready</span></div>
                <div class="stat-item"><span class="stat-value">${counts.blocked || 0}</span><span class="stat-label">Blocked</span></div>
                <div class="stat-item"><span class="stat-value">${counts.review || 0}</span><span class="stat-label">Review</span></div>
                <div class="stat-item"><span class="stat-value">${counts.backlog || 0}</span><span class="stat-label">Backlog</span></div>
            `;
        }

        /* ============================================================ */
        /* KANBAN VIEW                                                  */
        /* ============================================================ */
        async function loadKanban() {
            const priority = document.getElementById('kanbanPriority').value;
            const type = document.getElementById('kanbanType').value;
            const scope = document.getElementById('kanbanScope').value;

            let url = '/api/tickets?include_done=false';
            if (priority) url += '&priority=' + priority;
            if (type) url += '&type=' + type;
            if (scope) url += '&scope=' + scope;

            const data = await api(url);
            if (!data) return;
            const tickets = data.tickets || [];

            const columns = ['backlog', 'ready', 'in_progress', 'blocked', 'review', 'delegated'];
            const board = document.getElementById('kanbanBoard');

            board.innerHTML = columns.map(status => {
                const colTickets = tickets.filter(t => t.status === status);
                const colorVar = {
                    backlog: 'var(--bg-overlay0)',
                    ready: 'var(--blue)',
                    in_progress: 'var(--yellow)',
                    blocked: 'var(--red)',
                    review: 'var(--mauve)',
                    delegated: 'var(--teal)'
                }[status] || 'var(--text-muted)';

                const cards = colTickets.map(t => `
                    <div class="kanban-card" onclick="openDetail('${t.id}')">
                        <div class="kanban-card-id">${t.id}</div>
                        <div class="kanban-card-title">${truncate(t.title, 60)}</div>
                        <div class="kanban-card-meta">
                            ${badgeHtml(t.priority, 'badge')}
                            ${t.assignee ? '<span class="tag">' + t.assignee + '</span>' : ''}
                            ${t.type ? '<span class="tag">' + t.type + '</span>' : ''}
                        </div>
                    </div>
                `).join('');

                return `
                    <div class="kanban-column">
                        <div class="kanban-column-header">
                            <span class="kanban-column-title" style="color:${colorVar}">${status.replace(/_/g, ' ')}</span>
                            <span class="kanban-column-count">${colTickets.length}</span>
                        </div>
                        <div class="kanban-column-body">${cards || '<div class="empty-state"><p>No tickets</p></div>'}</div>
                    </div>
                `;
            }).join('');
        }

        function filterKanban() {
            const q = document.getElementById('kanbanSearch').value.toLowerCase();
            document.querySelectorAll('.kanban-card').forEach(card => {
                const text = card.textContent.toLowerCase();
                card.style.display = text.includes(q) ? '' : 'none';
            });
        }

        /* ============================================================ */
        /* LIST VIEW                                                    */
        /* ============================================================ */
        let listTickets = [];

        async function loadList() {
            const status = document.getElementById('listStatus').value;
            const priority = document.getElementById('listPriority').value;
            const type = document.getElementById('listType').value;
            const scope = document.getElementById('listScope').value;

            let url = '/api/tickets?';
            if (status) url += 'status=' + status + '&';
            if (priority) url += 'priority=' + priority + '&';
            if (type) url += 'type=' + type + '&';
            if (scope) url += 'scope=' + scope + '&';
            if (status === 'done' || status === 'cancelled') url += 'include_done=true&';

            const data = await api(url);
            if (!data) return;
            listTickets = data.tickets || [];
            renderList();
        }

        function sortList(field) {
            if (listSortField === field) {
                listSortAsc = !listSortAsc;
            } else {
                listSortField = field;
                listSortAsc = true;
            }
            renderList();
        }

        function renderList() {
            const sorted = [...listTickets].sort((a, b) => {
                const va = (a[listSortField] || '').toString().toLowerCase();
                const vb = (b[listSortField] || '').toString().toLowerCase();
                if (va < vb) return listSortAsc ? -1 : 1;
                if (va > vb) return listSortAsc ? 1 : -1;
                return 0;
            });

            const tbody = document.getElementById('listBody');
            tbody.innerHTML = sorted.map(t => `
                <tr class="clickable" onclick="openDetail('${t.id}')">
                    <td class="id-cell">${t.id}</td>
                    <td><span class="tag">${t.type || ''}</span></td>
                    <td>${badgeHtml(t.status, 'badge')}</td>
                    <td>${badgeHtml(t.priority, 'badge')}</td>
                    <td>${t.assignee || ''}</td>
                    <td class="title-cell">${truncate(t.title, 50)}</td>
                    <td>${progressHtml(t.progress)}</td>
                    <td class="date-cell">${t.due_date || ''}</td>
                </tr>
            `).join('');
        }

        function filterList() {
            const q = document.getElementById('listSearch').value.toLowerCase();
            document.querySelectorAll('#listBody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        }

        /* ============================================================ */
        /* DASHBOARD VIEW                                               */
        /* ============================================================ */
        async function loadDashboard(type, btn) {
            if (btn) {
                document.querySelectorAll('.dashboard-tabs .btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            }
            const el = document.getElementById('dashboardContent');
            el.textContent = 'Loading...';
            const data = await api('/api/dashboard/' + type);
            if (data) {
                el.textContent = data.content || 'No data';
            }
        }

        /* ============================================================ */
        /* PEOPLE VIEW                                                  */
        /* ============================================================ */
        async function loadPeople() {
            const data = await api('/api/people');
            if (!data) return;
            const people = data.people || [];
            const grid = document.getElementById('peopleGrid');

            if (!people.length) {
                grid.innerHTML = '<div class="empty-state"><div class="empty-state-icon">👥</div><h3>No People</h3><p>No people records found</p></div>';
                return;
            }

            grid.innerHTML = people.map(p => `
                <div class="person-card" onclick="openPersonDetail('${p.id || p.name}')">
                    <div class="person-name">${p.name || p.title || 'Unknown'}</div>
                    <div class="person-role">${p.role || ''}</div>
                    ${p.team ? '<span class="person-team">' + p.team + '</span>' : ''}
                    ${p.email ? '<div style="font-size:12px;color:var(--text-muted);margin-top:6px">' + p.email + '</div>' : ''}
                </div>
            `).join('');
        }

        function filterPeople() {
            const q = document.getElementById('peopleSearch').value.toLowerCase();
            document.querySelectorAll('.person-card').forEach(card => {
                card.style.display = card.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        }

        async function openPersonDetail(id) {
            /* re-use the detail modal for person info */
            const data = await api('/api/ticket/' + encodeURIComponent(id));
            if (!data || !data.ticket) { toast('Person not found', 'error'); return; }
            showDetailModal(data.ticket);
        }

        /* ============================================================ */
        /* TICKET DETAIL                                                */
        /* ============================================================ */
        async function openDetail(id) {
            document.getElementById('detailModal').classList.add('active');
            document.getElementById('detailBody').innerHTML = 'Loading...';
            document.getElementById('detailTitle').textContent = id;

            const data = await api('/api/ticket/' + encodeURIComponent(id));
            if (!data || !data.ticket) {
                document.getElementById('detailBody').innerHTML = '<p>Ticket not found</p>';
                return;
            }
            showDetailModal(data.ticket);
        }

        function showDetailModal(t) {
            const modal = document.getElementById('detailModal');
            modal.classList.add('active');
            modal.dataset.ticketId = t.id || '';
            document.getElementById('detailTitle').textContent = t.id || t.title || 'Detail';

            const fields = [
                ['Type', t.type],
                ['Status', t.status],
                ['Priority', t.priority],
                ['Assignee', t.assignee],
                ['Reporter', t.reporter],
                ['Project', t.project],
                ['Progress', t.progress != null ? t.progress + '%' : ''],
                ['Due Date', t.due_date],
                ['Created', t.created],
                ['Updated', t.updated],
                ['Member Of', t.member_of],
                ['Tags', Array.isArray(t.tags) ? t.tags.join(', ') : (t.tags || '')],
            ].filter(f => f[1]);

            const metaHtml = fields.map(f => `
                <div class="detail-field">
                    <label>${f[0]}</label>
                    <div class="value">${f[0] === 'Status' ? badgeHtml(f[1], 'badge') : (f[0] === 'Priority' ? badgeHtml(f[1], 'badge') : f[1])}</div>
                </div>
            `).join('');

            const body = t.body || t.description || '';

            /* parse comments from body */
            let commentsHtml = '';
            if (t.comments && t.comments.length) {
                commentsHtml = '<div class="comment-list"><h3 style="margin-bottom:8px;font-size:14px;color:var(--text-overlay)">Comments</h3>' +
                    t.comments.map(c => `
                        <div class="comment">
                            <div class="comment-header">
                                <span class="comment-author">${c.author || 'unknown'}</span>
                                <span>${c.date || ''}</span>
                            </div>
                            <div class="comment-body">${c.text || c.body || ''}</div>
                        </div>
                    `).join('') + '</div>';
            }

            document.getElementById('detailBody').innerHTML = `
                <div class="detail-meta">${metaHtml}</div>
                ${body ? '<div class="detail-body">' + body + '</div>' : ''}
                ${commentsHtml}
                <div class="comment-form">
                    <input type="text" id="commentInput" placeholder="Add a comment...">
                    <button class="btn btn-primary btn-small" onclick="submitComment('${t.id}')">Send</button>
                </div>
                <div style="display:flex;gap:8px;margin-top:16px;flex-wrap:wrap;">
                    <select id="moveStatus" style="flex:1">
                        <option value="">Move to...</option>
                        ${['backlog','ready','in_progress','blocked','review','delegated','done','cancelled']
                            .filter(s => s !== t.status)
                            .map(s => '<option value="' + s + '">' + s.replace(/_/g,' ') + '</option>')
                            .join('')}
                    </select>
                    <button class="btn btn-secondary btn-small" onclick="moveTicket('${t.id}')">Move</button>
                    <select id="editPriority" style="flex:1">
                        <option value="">Set priority...</option>
                        ${['critical','high','medium','low']
                            .filter(p => p !== t.priority)
                            .map(p => '<option value="' + p + '">' + p + '</option>')
                            .join('')}
                    </select>
                    <button class="btn btn-secondary btn-small" onclick="editPriority('${t.id}')">Set</button>
                </div>
            `;
        }

        async function submitComment(id) {
            const text = document.getElementById('commentInput').value.trim();
            if (!text) return;
            const data = await api('/api/ticket/' + id + '/comment', {
                method: 'POST',
                body: JSON.stringify({ text })
            });
            if (data && data.success) {
                toast('Comment added');
                document.getElementById('commentInput').value = '';
                openDetail(id);
            } else {
                toast(data?.message || 'Failed', 'error');
            }
        }

        async function moveTicket(id) {
            const status = document.getElementById('moveStatus').value;
            if (!status) return;
            const data = await api('/api/ticket/' + id + '/move', {
                method: 'POST',
                body: JSON.stringify({ status })
            });
            if (data && data.success) {
                toast(`Moved ${id} to ${status}`);
                closeModal('detailModal');
                refreshCurrentView();
            } else {
                toast(data?.message || 'Failed to move', 'error');
            }
        }

        async function editPriority(id) {
            const priority = document.getElementById('editPriority').value;
            if (!priority) return;
            const data = await api('/api/ticket/' + id + '/edit', {
                method: 'POST',
                body: JSON.stringify({ priority })
            });
            if (data && data.success) {
                toast('Priority updated');
                openDetail(id);
            } else {
                toast(data?.message || 'Failed', 'error');
            }
        }

        /* ============================================================ */
        /* CREATE                                                       */
        /* ============================================================ */
        function openCreateModal() {
            document.getElementById('createModal').classList.add('active');
            document.getElementById('createTitle').focus();
        }

        async function submitCreate() {
            const title = document.getElementById('createTitle').value.trim();
            if (!title) { toast('Title is required', 'error'); return; }

            const payload = {
                type: document.getElementById('createType').value,
                title,
                priority: document.getElementById('createPriority').value,
                assignee: document.getElementById('createAssignee').value.trim(),
                reporter: document.getElementById('createReporter').value.trim(),
                project: document.getElementById('createProject').value.trim(),
                due: document.getElementById('createDue').value.trim(),
                tags: document.getElementById('createTags').value.trim(),
                member_of: document.getElementById('createMemberOf').value.trim(),
                scope: document.getElementById('createScope').value,
            };

            const data = await api('/api/tickets', {
                method: 'POST',
                body: JSON.stringify(payload)
            });

            if (data && data.success) {
                toast('Created ' + (data.id || 'ticket'));
                closeModal('createModal');
                /* clear form */
                document.getElementById('createTitle').value = '';
                document.getElementById('createAssignee').value = '';
                document.getElementById('createReporter').value = '';
                document.getElementById('createProject').value = '';
                document.getElementById('createDue').value = '';
                document.getElementById('createTags').value = '';
                document.getElementById('createMemberOf').value = '';
                refreshCurrentView();
            } else {
                toast(data?.message || 'Failed to create', 'error');
            }
        }

        /* ============================================================ */
        /* GIT SYNC                                                     */
        /* ============================================================ */
        async function gitSync() {
            toast('Syncing...');
            const data = await api('/api/sync', { method: 'POST' });
            if (data && data.success) {
                toast('Sync complete');
            } else {
                toast(data?.message || 'Sync failed', 'error');
            }
        }

        /* ============================================================ */
        /* MODALS                                                       */
        /* ============================================================ */
        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        /* close on overlay click */
        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', e => {
                if (e.target === overlay) overlay.classList.remove('active');
            });
        });

        /* close on Escape */
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                document.querySelectorAll('.modal-overlay.active').forEach(m => m.classList.remove('active'));
            }
        });

        /* ============================================================ */
        /* COLLAB — SSE real-time collaboration                        */
        /* ============================================================ */
        const collab = {
            token: null,
            user: null,
            es: null,
            connected: false,
            presence: [],
        };

        function collabInit() {
            collab.token = localStorage.getItem('vimban_collab_token') || '';
            if (collab.token) collabConnect();
        }

        async function collabConnect() {
            if (collab.es) { collab.es.close(); collab.es = null; }

            /* 1. Hydrate from snapshot before subscribing to event stream */
            try {
                const snap = await fetch('/api/snapshot', { headers: { 'Authorization': 'Bearer ' + collab.token } });
                if (snap.ok) {
                    const snapData = await snap.json();
                    collab.presence = snapData.presence || [];
                    collabRenderPresence();
                }
            } catch (_) { /* non-fatal — SSE CONNECTED event will carry presence */ }

            /* 2. Subscribe to event stream (token-only, no ?user= — server resolves identity) */
            const url = '/api/events?token=' + encodeURIComponent(collab.token);
            collab.es = new EventSource(url);
            collab.es.onmessage = (e) => {
                try { collabHandle(JSON.parse(e.data)); } catch (_) {}
            };
            collab.es.onerror = () => {
                collab.connected = false;
                collabRenderPresence();
                /* EventSource auto-reconnects; no manual retry needed */
            };
        }

        function collabHandle(msg) {
            const { type, data } = msg;
            switch (type) {
                case 'CONNECTED':
                    collab.connected = true;
                    collab.user = data.user || collab.user;
                    collab.presence = data.presence || [];
                    collabRenderPresence();
                    break;
                case 'PRESENCE_JOIN':
                case 'PRESENCE_LEAVE':
                    collab.presence = data.presence || [];
                    collabRenderPresence();
                    break;
                case 'TICKET_CREATED':
                    if (data.user !== collab.user) {
                        toast('+ ' + data.user + ' created ' + data.ticket_id, 'success');
                        refreshCurrentView();
                    }
                    break;
                case 'TICKET_UPDATED':
                    if (data.user !== collab.user) {
                        toast('~ ' + data.user + ' updated ' + data.ticket_id, 'success');
                        refreshCurrentView();
                    }
                    break;
                case 'TICKET_COMMENT':
                    if (data.user !== collab.user) {
                        toast('> ' + data.user + ' commented on ' + data.ticket_id, 'success');
                    }
                    break;
                case 'TICKET_ARCHIVED':
                    if (data.user !== collab.user) {
                        toast('x ' + data.user + ' archived ' + data.ticket_id, 'success');
                        refreshCurrentView();
                    }
                    break;
            }
        }

        function collabRenderPresence() {
            const bar = document.getElementById('presenceBar');
            if (!bar) return;
            if (!collab.token) {
                bar.innerHTML = '';
                return;
            }
            if (!collab.connected || !collab.presence.length) {
                bar.innerHTML = '<span class="presence-offline" title="Disconnected">\u25CF</span>';
                return;
            }
            const dots = collab.presence.map(p =>
                '<span class="presence-dot" title="' + p.user + '">' +
                p.user.charAt(0).toUpperCase() + '</span>'
            ).join('');
            bar.innerHTML = '<span class="presence-label">online:</span>' + dots;
        }

        function openCollabSettings() {
            const token = prompt('API token (leave blank to disconnect):', collab.token || '');
            if (token === null) return;
            localStorage.setItem('vimban_collab_token', token);
            collab.token = token;
            collab.user  = null;  /* will be resolved from token by server on CONNECTED */
            if (token) {
                collabConnect();
            } else if (collab.es) {
                collab.es.close();
                collab.es = null;
                collab.connected = false;
                collab.presence = [];
                collabRenderPresence();
            }
        }

        /* ============================================================ */
        /* REFRESH                                                      */
        /* ============================================================ */
        function refreshCurrentView() {
            loadStats();
            if (currentView === 'kanban') loadKanban();
            else if (currentView === 'list') loadList();
            else if (currentView === 'dashboard') loadDashboard('daily');
            else if (currentView === 'people') loadPeople();
        }

        /* ============================================================ */
        /* KEYBOARD SHORTCUTS                                           */
        /* ============================================================ */
        document.addEventListener('keydown', e => {
            /* only when not focused on inputs */
            if (['INPUT','TEXTAREA','SELECT'].includes(document.activeElement.tagName)) return;

            if (e.key === 'c') openCreateModal();
            else if (e.key === 'r') refreshCurrentView();
            else if (e.key === '1') { document.querySelector('.nav-tab:nth-child(1)').click(); }
            else if (e.key === '2') { document.querySelector('.nav-tab:nth-child(2)').click(); }
            else if (e.key === '3') { document.querySelector('.nav-tab:nth-child(3)').click(); }
            else if (e.key === '4') { document.querySelector('.nav-tab:nth-child(4)').click(); }
            else if (e.key === '/') { e.preventDefault(); document.querySelector('.view-panel.active .search-input')?.focus(); }
            else if (e.key === 's' && !e.ctrlKey) gitSync();
        });

        /* ============================================================ */
        /* INIT                                                         */
        /* ============================================================ */
        loadStats();
        loadKanban();
        collabInit();
    </script>
</body>
</html>"""


# ============================================================================
# API ROUTES
# ============================================================================
@app.route('/')
async def index():
    """Serve the main HTML page."""
    return HTML_TEMPLATE


@app.route('/api/tickets')
async def api_list_tickets():
    """List tickets with optional filters."""
    status: str = request.args.get('status', '')
    ticket_type: str = request.args.get('type', '')
    assignee: str = request.args.get('assignee', '')
    priority: str = request.args.get('priority', '')
    project: str = request.args.get('project', '')
    scope: str = request.args.get('scope', '')
    include_done: bool = request.args.get('include_done', 'false').lower() == 'true'

    tickets: list[dict[str, Any]] = list_tickets(
        status=status,
        ticket_type=ticket_type,
        assignee=assignee,
        priority=priority,
        project=project,
        work=(scope == 'work'),
        personal=(scope == 'personal'),
        include_done=include_done,
    )
    return jsonify({'tickets': tickets})


@app.route('/api/tickets', methods=['POST'])
async def api_create_ticket():
    """Create a new ticket."""
    data: dict = await request.get_json()
    if not data:
        return jsonify({'success': False, 'message': 'No data provided'}), 400

    prefix = data.get('prefix', None)
    success, msg = create_ticket(
        ticket_type=data.get('type', 'task'),
        title=data.get('title', ''),
        priority=data.get('priority', 'medium'),
        assignee=data.get('assignee', ''),
        reporter=data.get('reporter', ''),
        project=data.get('project', ''),
        tags=data.get('tags', ''),
        due=data.get('due', ''),
        member_of=data.get('member_of', ''),
        work=(data.get('scope') == 'work'),
        personal=(data.get('scope') == 'personal'),
        prefix=prefix if prefix else None,
    )

    if success:
        ticket_id = msg
        title = data.get('title', '')
        ticket_type = data.get('type', 'task')
        await _broadcast_event('TICKET_CREATED', {'ticket_id': ticket_id, 'title': title, 'type': ticket_type, 'status': 'backlog', 'user': getattr(g, 'vimban_user', None) or request.headers.get('X-Vimban-User', 'unknown')})
        return jsonify({'success': True, 'id': msg})
    return jsonify({'success': False, 'message': msg}), 400


@app.route('/api/ticket/<ticket_id>')
async def api_get_ticket(ticket_id: str):
    """Get a single ticket."""
    ticket: Optional[dict] = get_ticket(ticket_id)
    if ticket is None:
        return jsonify({'error': 'Ticket not found'}), 404
    return jsonify({'ticket': ticket})


@app.route('/api/ticket/<ticket_id>/move', methods=['POST'])
async def api_move_ticket(ticket_id: str):
    """Move a ticket to a new status."""
    data: dict = await request.get_json()
    new_status: str = data.get('status', '')
    if not new_status:
        return jsonify({'success': False, 'message': 'Status required'}), 400

    success, msg = move_ticket(ticket_id, new_status)
    if success:
        await _broadcast_event('TICKET_UPDATED', {'ticket_id': ticket_id, 'field': 'status', 'value': new_status, 'user': getattr(g, 'vimban_user', None) or request.headers.get('X-Vimban-User', 'unknown')})
    return jsonify({'success': success, 'message': msg})


